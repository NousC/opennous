# =============================================================================
# Nous — Environment Variables (development)
# Copy this file to .env and fill in your values.
# For production / Docker self-host, use nous.env.example instead.
# =============================================================================

# =============================================================================
# === Supabase (required)
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# === API Server
# =============================================================================
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000

# =============================================================================
# === Frontend
# =============================================================================
VITE_API_URL=http://localhost:3000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# === AI Providers (at least one required for memory synthesis)
# =============================================================================
ANTHROPIC_API_KEY=your-anthropic-key
# OPENAI_API_KEY=your-openai-key        # optional alternative

# =============================================================================
# === Integrations (all optional — connect the ones you use)
# =============================================================================

# --- Google Calendar ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# --- LinkedIn via Unipile ---
UNIPILE_API_KEY=
UNIPILE_DSN=

# --- Email (Gmail / Outlook) ---
# Configured per-user via OAuth in the app. No global key needed.

# --- Webhook security ---
# Shared HMAC secret used to verify inbound signal webhooks (RB2B, Signalbase, …).
SIGNAL_HMAC_SECRET=your-webhook-secret

# =============================================================================
# === Deployment Mode
# =============================================================================

# Self-hosted? Leave this true and skip the rest of this section.
# Self-host: no billing, no ops metering, no Stripe — everything is unlocked.
SELF_HOSTED=true

# --- Platform operator allowlists (cloud only — LEAVE EMPTY FOR SELF-HOST) ---
# Gate the platform-operator surface (CMS, Roadmap, Changelog, Updates,
# Resources) and VIP plan access. Empty by default = no account is ever an
# operator on a self-hosted instance. Only Nous Cloud sets these.
# ADMIN_EMAILS=founder@example.com
# VIP_EMAILS=founder@example.com

# --- Hosted (opennous.cloud) only — ignore all of the below for self-host ---
#
# To enable cloud billing you need: STRIPE_SECRET_KEY + STRIPE_WEBHOOK_SECRET
# + VITE_STRIPE_PUBLISHABLE_KEY, plus a Stripe price ID for each plan/pack.
# Full list (with the corresponding env-var names) lives in
# apps/api/src/lib/plans.mjs — search for `stripePriceEnv`. Operators creating
# the Stripe products copy each price id into the matching env var.
# When STRIPE_SECRET_KEY is unset, all billing routes short-circuit cleanly.

# =============================================================================
# === Credential Encryption
# =============================================================================
# 64-char hex string used to AES-256-CBC encrypt stored integration credentials.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

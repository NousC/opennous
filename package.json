{
  "name": "nous",
  "private": true,
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' run dev",
    "dev:api": "pnpm --filter ./apps/api run dev",
    "dev:frontend": "pnpm --filter ./apps/frontend run dev",
    "dev:worker": "pnpm --filter ./apps/worker run dev",
    "dev:mcp": "pnpm --filter ./apps/mcp run dev",
    "build": "pnpm --filter './apps/*' run build",
    "test": "pnpm --filter './apps/api' run test && pnpm --filter './apps/worker' run test",
    "lint": "pnpm --filter './apps/*' --filter './packages/*' run lint",
    "typecheck": "pnpm --filter './apps/*' --filter './packages/*' run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}

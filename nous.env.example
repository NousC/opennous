# ── Domains (used by Caddy for SSL + routing) ─────────────────────────────────
# These two also drive OAuth redirects, webhook callbacks, and email links:
# the app derives APP_URL=https://$APP_DOMAIN and API_URL=https://$API_DOMAIN
# from them automatically (see apps/api/src/bootEnv.mjs). Set APP_URL / API_URL
# explicitly only if your app and API live somewhere other than these domains.
APP_DOMAIN=app.yourdomain.com
API_DOMAIN=api.yourdomain.com
# Hosted MCP server (Streamable HTTP). Point a DNS record at the server; Caddy
# auto-provisions TLS. Remote MCP clients (n8n cloud, etc.) connect to https://$MCP_DOMAIN/mcp
MCP_DOMAIN=mcp.yourdomain.com

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Frontend (baked into JS bundle at build time) ──────────────────────────────
VITE_SUPABASE_URL=https://yourproject.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth / Security ───────────────────────────────────────────────────────────
# Random 32-byte hex string — used to encrypt OAuth tokens at rest
ENCRYPTION_KEY=

# ── Self-host ─────────────────────────────────────────────────────────────────
# Master self-host switch. Set this on every self-hosted instance.
#
# SELF_HOSTED=true gives you the graph, unmetered and uncapped: Accounts,
# Activities, the ICP file, the Graph, all 20+ integrations, webhooks, and the
# full API/MCP surface. No account limit, no billing, no plan enforcement.
# Extraction runs on YOUR ANTHROPIC_API_KEY, which is exactly why there's nothing
# to meter — your graph costs us nothing to fill.
#
# It does NOT include the Cloud managed layer (CRM sync, lead lists, and the ICP
# MODEL that learns from your won/lost deals — the ICP FILE itself is open), nor
# the team layer (the in-app agent, Adoption, Playbooks, Tasks, Skills, and the
# Salesforce/HubSpot/Slack connectors).
# See CLOUD_ONLY_FEATURES in apps/api/src/lib/access.mjs.
#
# ⚠️ On Nous Cloud this MUST be unset. Leaving it true disables billing entirely
# and hands every customer the whole product for free.
SELF_HOSTED=true

# DISABLE_SIGNUPS=true closes public registration: the FIRST account created
# becomes the owner, and after that nobody can self-register. Add teammates via
# the in-app invite (Settings → Team). Leave unset/false for an open instance.
#
# Belt-and-suspenders: also turn OFF "Allow new users to sign up" in your
# Supabase project (Authentication → Sign In / Providers) — that shuts the door
# at the auth layer too, since signup goes browser → Supabase directly.
# DISABLE_SIGNUPS=true

# ── Cloud / team features (optional for self-host) ────────────────────────────
# Skip these for a single-tenant self-host. They power features that the
# hosted Nous Cloud uses, and most self-hosters do not need them.
#
# SIGNAL_HMAC_SECRET signs per-workspace tokens for RB2B / Signalbase ingest.
# Only needed if you ingest from RB2B or Signalbase.
SIGNAL_HMAC_SECRET=

# RESEND_API_KEY sends workspace invitation emails. Only needed if you
# invite teammates to your workspace. Without it, invites still create
# accounts, but no email is sent.
RESEND_API_KEY=
# If you set RESEND_API_KEY, also set the sender to an address on YOUR Resend
# verified domain — otherwise the send is rejected. Reply-to defaults to the
# from address when left blank.
RESEND_FROM_EMAIL=
RESEND_REPLY_TO=

# ── Platform operator allowlists (cloud only — LEAVE EMPTY FOR SELF-HOST) ──────
# These gate the platform-operator surface (CMS, Roadmap, Changelog, Updates,
# Resources) and VIP plan access. Both are EMPTY by default, which means NO
# account can ever reach the admin surface on a self-hosted instance — this is
# intentional. Only the hosted Nous Cloud sets these. Comma-separated emails.
# ADMIN_EMAILS=founder@example.com
# VIP_EMAILS=founder@example.com

# ── CORS (comma-separated allowed origins) ────────────────────────────────────
# Leave unset to allow all origins (fine for self-hosted / local dev).
# Set this on cloud to lock down to your frontend domain.
# CORS_ORIGINS=https://app.opennous.cloud

# ── Integrations ─────────────────────────────────────────────────────────────
# Google OAuth — for Gmail + Calendar sync
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.yourdomain.com/api/oauth/google/callback

# Slack OAuth — for DM polling
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://api.yourdomain.com/api/oauth/slack/callback

# Salesforce OAuth — setup guide: docs/providers/salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=https://api.yourdomain.com/api/workflow-providers/salesforce/oauth/callback
SALESFORCE_LOGIN_URL=https://login.salesforce.com

# Unipile — for LinkedIn webhook
UNIPILE_API_KEY=
UNIPILE_DSN=

# Enrichment providers
PROSPERO_API_KEY=

# Let workspaces WITHOUT their own Prospeo key enrich on the platform key above.
# This is Nous's money, so it is OFF unless you set it to exactly "true".
# Leave it unset in production: enrichment is not a product we sell, and
# resolveContact fires enrichment on every contact a webhook creates, so an open
# fallback is an unbounded bill. Customers with their own Prospeo key are
# unaffected either way.
ENRICHMENT_BUILTIN_FALLBACK=
OPENAI_API_KEY=

# ── Webhook secrets (shared secret to validate inbound webhook payloads) ─────────
# Set these to a random string and configure the same value in each integration's dashboard.
# Only the integrations you actually connect need a secret — leave the rest blank.
LINKEDIN_WEBHOOK_SECRET=
INSTANTLY_WEBHOOK_SECRET=
CALENDLY_WEBHOOK_SECRET=
FIREFLIES_WEBHOOK_SECRET=
FATHOM_WEBHOOK_SECRET=
RB2B_WEBHOOK_SECRET=
# Outbound sequencers (reply/bounce ingestion for Lead Lists)
HEYREACH_WEBHOOK_SECRET=
LEMLIST_WEBHOOK_SECRET=
SMARTLEAD_WEBHOOK_SECRET=
EMAILBISON_WEBHOOK_SECRET=

# ── Optional: outbound form-notification webhooks ────────────────────────────────
# In-app "feedback"/"idea" submissions and landing-page waitlist signups can be
# forwarded to an automation endpoint (e.g. n8n / Zapier / Make). Both are OPTIONAL:
# if unset the forms still work — feedback is accepted, the waitlist still posts to
# the app — they just aren't forwarded. Keeps any private endpoint out of source.
FEEDBACK_WEBHOOK_URL=
# Read at BUILD time by the frontend, so it MUST keep the VITE_ prefix.
VITE_WAITLIST_WEBHOOK_URL=

# ── Optional: weekly LinkedIn engagement run (Scale plan) ─────────────────────
# When APIFY_TOKEN is set, the worker scrapes engagers off each connected
# workspace's own recent LinkedIn posts every Monday into a native
# "LinkedIn Engagers" lead list. Unset → the whole feature is off.
APIFY_TOKEN=
# Force-enable specific workspaces regardless of plan (dogfood / pilots), CSV.
LINKEDIN_ENGAGEMENT_WORKSPACES=
# Tuning (optional): scrape window, max posts/run, profile depth ('main'|'short').
# ENGAGEMENT_WINDOW_DAYS=7
# ENGAGEMENT_MAX_POSTS=5
# ENGAGEMENT_PROFILE_MODE=main

# ── Optional: Stripe (cloud / hosted only) ────────────────────────────────────
# Leave blank for self-hosted. Set these to enable billing UI.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Separate secret for the inbound Stripe-event ingestion webhook (dogfood signals).
STRIPE_INBOUND_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# ── Optional: analytics & monitoring ─────────────────────────────────────────
VITE_POSTHOG_KEY=
VITE_GOOGLE_ANALYTICS_ID=

# ── Optional: docs link override ──────────────────────────────────────────────
# Where the in-app "Docs" links point. Defaults to https://docs.opennous.cloud.
VITE_DOCS_URL=

# ── VITE_API_URL ──────────────────────────────────────────────────────────────
# Leave empty when using the nginx same-domain proxy (single domain, no Caddy).
# Set to https://api.yourdomain.com when api is on a separate subdomain (Caddy / cloud).
# VITE_API_URL=https://api.yourdomain.com

# ── Optional: port (default 80) — only used when running WITHOUT Caddy ─────────
# PORT=80
